{
  "name": "@michalfidor/playswag",
  "version": "1.8.2",
  "author": "Michał Fidor <michal.fidor@gmail.com>",
  "description": "Playwright API coverage tracking against Swagger/OpenAPI specifications",
  "keywords": [
    "playwright",
    "swagger",
    "openapi",
    "api-coverage",
    "testing",
    "coverage"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichalFidor/playswag.git"
  },
  "bugs": {
    "url": "https://github.com/MichalFidor/playswag/issues"
  },
  "homepage": "https://github.com/MichalFidor/playswag#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/types/reporter.d.ts",
        "default": "./dist/esm/reporter.js"
      },
      "require": {
        "types": "./dist/types/reporter.d.cts",
        "default": "./dist/cjs/reporter.cjs"
      }
    }
  },
  "files": [
    "dist",
    "assets",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/unit",
    "test:examples": "vitest run --config vitest.examples.config.ts",
    "test:integration": "playwright test --config=playwright.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "demo": "npm run build && node scripts/demo-report.mjs && open demo-report.html",
    "demo:md": "npm run build && node scripts/demo-coverage-md.mjs",
    "link": "npm install && npm run build && npm link @playwright/test && npm link",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.20.0"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "openapi-types": "^12.1.3",
    "picomatch": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/picomatch": "^4.0.2",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
